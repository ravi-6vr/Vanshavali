{
  "name": "vanshavali",
  "version": "1.0.0",
  "description": "Vanshavali - Family Lineage Tracker with Vedic Roots",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "node server.js",
    "build": "vite build",
    "preview": "vite preview",
    "desktop": "npm run build && concurrently \"npm run server\" \"npm run electron\"",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run server\" \"npm run client\" \"node electron/wait-and-launch.cjs\"",
    "seed": "node scripts/seed-demo.js",
    "start": "node server.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "d3": "^7.9.0",
    "express": "^5.1.0",
    "i18next": "^25.8.14",
    "leaflet": "^1.9.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.6",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.6.1",
    "uuid": "^11.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^36.9.5",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5"
  }
